# Copy this file to .env and fill in real values.
# Every value here maps 1:1 to a field in app/config.py (Settings).

# ---------------------------------------------------------------------------
# App / server
# ---------------------------------------------------------------------------
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---------------------------------------------------------------------------
# LLM (Groq) -- REQUIRED to run campaigns
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=openai/gpt-oss-120b
TEMPERATURE=0.4
MAX_TOKENS=2048

# ---------------------------------------------------------------------------
# Switches ( can also be changed live via PATCH /api/v1/config)
# ---------------------------------------------------------------------------
DEFAULT_DATA_SOURCE=csv          # csv | synthetic
DRY_RUN=true                     # true = simulate email sends, false = real SMTP
REPLY_MODE=simulated             # simulated | real_inbox

# ---------------------------------------------------------------------------
# Resilience / rate limiting
# ---------------------------------------------------------------------------
RETRY_COUNT=5
RATE_LIMIT_DELAY=1.2
BACKOFF_BASE=2.0
TPM_LIMIT=8000
TPM_SAFETY_MARGIN=0.85
CACHE_ENABLED=true

# ---------------------------------------------------------------------------
# SMTP (only used when DRY_RUN=false)
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_SENDER_ADDRESS=sales-ai@yourcompany.com

# ---------------------------------------------------------------------------
# (Planned to implement later)
# Storage (Docker volume mount points -- see docker-compose.yml)
# ---------------------------------------------------------------------------
STORAGE_DIR=storage
UPLOADS_DIR=storage/uploads
OUTPUT_DIR=storage/outputs
REPORT_DIR=storage/reports
LOG_DIR=storage/logs

LOG_LEVEL=INFO
